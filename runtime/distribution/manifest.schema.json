{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/woocommerce-cloud/distribution-manifest.schema.json",
  "title": "WooCommerce Cloud Distribution Manifest",
  "description": "Metadata for a versioned WordPress runtime distribution artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "distribution",
    "version",
    "wordpress",
    "woocommerce",
    "plugins",
    "checksum"
  ],
  "properties": {
    "distribution": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable distribution identifier."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "Semantic version of the complete artifact."
    },
    "wordpress": {
      "$ref": "#/$defs/component"
    },
    "woocommerce": {
      "$ref": "#/$defs/component"
    },
    "theme": {
      "$ref": "#/$defs/component"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "muPlugin": {
      "$ref": "#/$defs/component"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["default", "performance", "security"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checksum": {
      "$ref": "#/$defs/checksum"
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256"]
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
