{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI-Kit: Validate workflow",
      "type": "shell",
      "command": "ai-kit",
      "args": ["validate"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Workflow status",
      "type": "shell",
      "command": "ai-kit",
      "args": ["status"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Ready tasks",
      "type": "shell",
      "command": "ai-kit",
      "args": ["ready"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Poll workflow events",
      "type": "shell",
      "command": "ai-kit",
      "args": ["events", "--workflow-id", "${input:workflowId}", "--after-cursor", "${input:eventCursor}", "--wait-ms", "${input:eventWaitMs}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Watch workflow events",
      "type": "shell",
      "command": "ai-kit",
      "args": ["watch", "--workflow-id", "${input:workflowId}", "--after-cursor", "${input:eventCursor}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Route task",
      "type": "shell",
      "command": "ai-kit",
      "args": ["route", "${input:taskId}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Copilot claim next task",
      "type": "shell",
      "command": "ai-kit",
      "args": ["agent", "claim", "--workflow-id", "${input:workflowId}", "--client-id", "copilot-extension"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Copilot load context",
      "type": "shell",
      "command": "ai-kit",
      "args": ["agent", "context", "--workflow-id", "${input:workflowId}", "--task-id", "${input:taskId}", "--client-id", "copilot-extension", "--attempt-id", "${input:attemptId}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Copilot heartbeat",
      "type": "shell",
      "command": "ai-kit",
      "args": ["agent", "heartbeat", "--workflow-id", "${input:workflowId}", "--task-id", "${input:taskId}", "--client-id", "copilot-extension", "--attempt-id", "${input:attemptId}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Copilot submit result",
      "type": "shell",
      "command": "ai-kit",
      "args": ["agent", "result", "--workflow-id", "${input:workflowId}", "--task-id", "${input:taskId}", "--client-id", "copilot-extension", "--attempt-id", "${input:attemptId}", "--status", "${input:resultStatus}", "--summary", "${input:resultSummary}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Copilot finish current task",
      "type": "shell",
      "command": "ai-kit",
      "args": ["copilot", "finish", "--summary", "${input:resultSummary}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "AI-Kit: Run configured QA",
      "type": "shell",
      "command": "ai-kit-gate",
      "args": ["${input:workflowId}", "--once"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "workflowId",
      "type": "promptString",
      "description": "AI-Kit workflow ID",
      "default": "default"
    },
    {
      "id": "taskId",
      "type": "promptString",
      "description": "AI-Kit task ID"
    },
    {
      "id": "attemptId",
      "type": "promptString",
      "description": "AI-Kit claim attempt ID"
    },
    {
      "id": "eventCursor",
      "type": "promptString",
      "description": "Last consumed workflow event cursor",
      "default": "0"
    },
    {
      "id": "eventWaitMs",
      "type": "promptString",
      "description": "Event poll wait in milliseconds",
      "default": "30000"
    },
    {
      "id": "resultStatus",
      "type": "pickString",
      "description": "Implementation result status",
      "options": ["pass", "fail"],
      "default": "pass"
    },
    {
      "id": "resultSummary",
      "type": "promptString",
      "description": "Implementation result summary"
    }
  ]
}
