# Runtime configuration for platform-agent.
# Install as /etc/platform-agent/agent.env with mode 0600.

PLATFORM_AGENT_NODE_ID=node-1
PLATFORM_AGENT_ID=
PLATFORM_AGENT_SAAS_BASE_URL=https://saas.example.test
PLATFORM_AGENT_MU_PLUGIN_BASE_URL=http://127.0.0.1/wp-json
PLATFORM_AGENT_AUTH_TOKEN=
PLATFORM_AGENT_REGISTRATION_TOKEN=

# Compatibility variables consumed by older daemon wiring.
PLATFORM_AGENT_WORDPRESS_URL=http://127.0.0.1/wp-json
PLATFORM_AGENT_WORDPRESS_AUTH_TOKEN=

# Optional metadata and capability advertisement.
PLATFORM_AGENT_HOSTNAME=
PLATFORM_AGENT_CAPABILITIES='{"provisioning":true,"backup":true,"ssl":true}'
PLATFORM_AGENT_VERSIONS='{"agent":"dev"}'
PLATFORM_AGENT_VERSION=dev

# Positive Go durations. Defaults are 30s, 30s, and 10s.
PLATFORM_AGENT_POLL_INTERVAL=30s
PLATFORM_AGENT_HEARTBEAT_INTERVAL=30s
PLATFORM_AGENT_REQUEST_TIMEOUT=10s

# Legacy aliases accepted during migration; canonical names above take precedence.
# PLATFORM_AGENT_CONTROL_PLANE_URL=https://saas.example.test
