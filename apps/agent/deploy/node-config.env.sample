# node-config.env — SYSTEM-mode template for a real VPS (Ubuntu/Debian, root).
# Copy to apps/agent/deploy/node-config.env, edit the values marked EDIT,
# then: sudo bash apps/agent/deploy/install-node.sh --system --config apps/agent/deploy/node-config.env
#
# For a pure multisite SCALE test you do NOT need the SaaS control plane — the
# Runtime operates standalone; drive it via the CLI / spike harness.

NODE_MODE=system

# ---- WordPress (subdirectory multisite) ----
# For a scale test, HTTP + the VPS IP or a hostname is fine (no SSL needed).
WP_URL=http://REPLACE_WITH_VPS_IP_OR_HOST      # EDIT (e.g. http://203.0.113.10)
WP_TITLE="ooio Runtime Node"
WP_VERSION=latest
WP_PATH=/var/www/wordpress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD  # EDIT
WP_ADMIN_EMAIL=admin@example.com                # EDIT
# Absolute path to the cloned repo on the VPS:
MU_PLUGIN_SOURCE=/opt/ooio/runtime/mu-plugin/platform-core.php          # EDIT if repo path differs
DISTRIBUTION_INSTALLER=/opt/ooio/runtime/distribution/install-plugins.sh # EDIT if repo path differs

# ---- MariaDB (system service, port 3306) ----
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=ooio_wp
MARIADB_USER=ooio
MARIADB_PASSWORD=REPLACE_WITH_DB_PASSWORD       # EDIT
MARIADB_ROOT_PASSWORD=                          # leave empty if root uses socket auth

# ---- Redis object cache (system service) ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_SERVICE=redis-server
REDIS_PACKAGE=redis-server

# ---- LudicrousDB (db routing, single pool) ----
# LudicrousDB, not HyperDB: HyperDB is unmaintained and fatals on WP 6.4+/WooCommerce.
LUDICROUSDB_ENABLED=true
LUDICROUSDB_DROPIN_TARGET="${WP_PATH}/wp-content/db.php"
# Keep at ABSPATH (WordPress root); LudicrousDB also accepts wp-content/:
LUDICROUSDB_CONFIG_FILE="${WP_PATH}/db-config.php"
PLUGIN_SET_ENABLED=true

# ---- Web tier ----
PHP_FPM_SERVICE=                 # empty = auto-detect (e.g. php8.3-fpm)
PHP_FPM_ADDRESS=127.0.0.1:9000
CADDY_SITE_ADDRESS=:80           # HTTP for scale test; :443 + a domain for SSL later
CADDY_SERVICE=caddy

# ---- Platform secret + Agent ----
# Generate: openssl rand -hex 32
PLATFORM_CORE_SHARED_SECRET=REPLACE_WITH_openssl_rand_hex_32   # EDIT
PLATFORM_AGENT_NODE_ID=node-01
# SaaS not needed for a standalone scale test; leave empty (agent will idle on jobs):
PLATFORM_AGENT_CONTROL_PLANE_URL=
PLATFORM_AGENT_REGISTRATION_TOKEN=
PLATFORM_AGENT_CAPABILITIES='{"provisioning":true,"backup":true,"ssl":true}'
PLATFORM_AGENT_VERSIONS='{"agent":"1.0.0"}'
PLATFORM_AGENT_WORDPRESS_URL="${WP_URL}/wp-json"
# Defaults to PLATFORM_CORE_SHARED_SECRET when omitted.
PLATFORM_AGENT_WORDPRESS_AUTH_TOKEN=

# Build the agent binary for the VPS arch first (on the VPS: `cd apps/agent && go build -o /tmp/platform-agent .`)
# then point to it, or let install-node.sh find a prebuilt one:
# AGENT_BINARY=/tmp/platform-agent
