# Copy to apps/agent/deploy/node-config.env and edit for the target node.
# This file is sourced as a shell environment file by install-node.sh.

NODE_MODE=prefix
NODE_PREFIX="$HOME/ooio-devenv"

WP_URL=http://127.0.0.1
WP_TITLE="WooCommerce Cloud Node"
WP_VERSION=latest
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-me-in-development
WP_ADMIN_EMAIL=admin@example.invalid
WP_PATH="${NODE_PREFIX}/var/www/wordpress"
MU_PLUGIN_SOURCE="/absolute/path/to/ooio/runtime/mu-plugin/platform-core.php"

MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=wordpress
MARIADB_USER=wordpress
MARIADB_PASSWORD=change-me-in-development
MARIADB_ROOT_PASSWORD=
MARIADB_DATA_DIR="${NODE_PREFIX}/var/lib/mysql"
MARIADB_SOCKET="${NODE_PREFIX}/run/mariadb/mariadb.sock"

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_SERVICE=redis-server
REDIS_PACKAGE=redis-server
REDIS_DATA_DIR="${NODE_PREFIX}/var/lib/redis"
REDIS_PID_FILE="${NODE_PREFIX}/run/redis/redis-server.pid"
REDIS_LOG_FILE="${NODE_PREFIX}/var/log/redis/redis-server.log"

# LudicrousDB, not HyperDB: HyperDB is unmaintained and fatals on WP 6.4+/WooCommerce.
LUDICROUSDB_ENABLED=true
LUDICROUSDB_DROPIN_TARGET="${WP_PATH}/wp-content/db.php"
# Keep db-config.php at the WordPress root (ABSPATH) — works for LudicrousDB
# (which also accepts wp-content/) and matches the legacy layout.
LUDICROUSDB_CONFIG_FILE="${WP_PATH}/db-config.php"
DISTRIBUTION_INSTALLER="/absolute/path/to/ooio/runtime/distribution/install-plugins.sh"
PLUGIN_SET_ENABLED=true

PHP_FPM_SERVICE=
PHP_FPM_ADDRESS=127.0.0.1:9000
CADDY_SITE_ADDRESS=:80
CADDY_SERVICE=caddy

PLATFORM_CORE_SHARED_SECRET=replace-with-a-long-random-secret
PLATFORM_AGENT_CONTROL_PLANE_URL=
PLATFORM_AGENT_REGISTRATION_TOKEN=
PLATFORM_AGENT_NODE_ID=
PLATFORM_AGENT_CAPABILITIES='{"provisioning":true,"backup":true,"ssl":true}'
PLATFORM_AGENT_VERSIONS='{"agent":"dev"}'
PLATFORM_AGENT_WORDPRESS_URL=http://127.0.0.1
# Defaults to PLATFORM_CORE_SHARED_SECRET when omitted.
PLATFORM_AGENT_WORDPRESS_AUTH_TOKEN=

# Optional paths. Defaults are derived from NODE_PREFIX or system paths.
# WP_CLI_PATH=
# AGENT_BINARY=
# AGENT_INSTALL_PATH=
# AGENT_CONFIG_DIR=
# SERVICE_FILE=
# CADDY_CONFIG_FILE=
